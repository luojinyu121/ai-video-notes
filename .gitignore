# 输出文件（笔记、字幕缓存、日志）
output/
note_results/
logs/

# 音频缓存（可能很大）
*.m4a
*.mp3
*.wav
*.mp4

# Cookie 临时文件
.cookies_*.txt

# Python
__pycache__/
*.pyc
.venv/
venv/

# 注意: config/settings.json 已纳入版本管理
# Cookie 字段为占位符，用户克隆后需填入自己的 Cookie

# Claude Code（插件 hook 配置文件除外）
.claude/*
!.claude/settings.json
!.claude/hook-config.json
!.claude/hooks/
!.claude/hooks/check-naming.py

# IDE
.vscode/
.idea/
